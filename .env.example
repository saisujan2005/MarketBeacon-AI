# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@localhost:5432/marketbeacon

# ── Groq LLM ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# ── Email Notifications (Resend / SendGrid) ──────────────────────────────────
# resend.com key (Preferred)
RESEND_API_KEY=re_your_resend_api_key
# sendgrid.com key (Fallback)
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# ── Browser Web Push (PWA) ───────────────────────────────────────────────────
# Generate VAPID key pairs using: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BDp_k9sL_V8oD4p3o39WGdyb3FY3miM1xjKhA2wGcGFXpZSUrAm
VAPID_PRIVATE_KEY=your_private_vapid_key
VAPID_CLAIMS_EMAIL=alerts@marketbeacon.ai

# ── Twitter/X Adaptive Scraper (Optional) ───────────────────────────────────
TWITTER_USERNAME=your_twitter_username
TWITTER_PASSWORD=your_twitter_password
TWITTER_EMAIL=your_twitter_email

# ── Scheduler Configurations ──────────────────────────────────────────────────
NEWS_INTERVAL_MINUTES=10
TWITTER_MARKET_HOURS_INTERVAL=2
TWITTER_OFF_HOURS_INTERVAL=15
MARKET_OPEN_HOUR=9
MARKET_CLOSE_HOUR=16

# ── Alert Engine Threshold ────────────────────────────────────────────────────
ALERT_THRESHOLD=85

# ── App Environments ──────────────────────────────────────────────────────────
APP_ENV=development
FRONTEND_URL=http://localhost:5173
JWT_SECRET=your_production_jwt_64_character_secret_key
